.container {
  min-height: 100vh;
  background-color: #0A1C3A;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

/* 无历史记录时的样式 */
.empty-history {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  color: rgba(255, 255, 255, 0.5);
}

.empty-text {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  text-align: center;
}

/* 历史记录列表样式 */
.history-list {
  width: 100%;
  flex: 1;
  margin-bottom: 40rpx;
}

.history-item {
  background-color: rgba(255,255,255,0.15);
  border-radius: 48rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.history-item:hover {
  background-color: rgba(255,255,255,0.2);
  transform: translateY(-2rpx);
}

.history-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.medicine-name {
  font-size: 36rpx;
  color: white;
  font-weight: bold;
  flex: 1;
}

.history-time {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-left: 20rpx;
  white-space: nowrap;
}

.bottom-tip {
  text-align: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin: 40rpx 0;
}

/* 返回按钮样式 */
.back-btn {
  width: 80%;
  background-color: #FFA500;
  border-radius: 60rpx;
  color: white;
  font-size: 40rpx;
  font-weight: bold;
  padding: 28rpx 0;
  border: none;
  margin-top: 20rpx;
  margin-bottom: 40rpx;
}